# Google Gemini — AI mission planner (optional; uses rule-based fallback if unset)
GEMINI_API_KEY=your_gemini_api_key_here

# Space-Track.org — primary TLE catalog (~20k objects, free account at https://www.space-track.org)
# If unset, the app falls back to Celestrak automatically.
SPACE_TRACK_USER=your_space_track_username
SPACE_TRACK_PASSWORD=your_space_track_password
